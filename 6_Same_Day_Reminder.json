    },
    {
      "parameters": {
        "url": "https://script.google.com/macros/s/AKfycbzoYisQi9UxCYe7NBypqS3jQTAWOkGgfvyLF09Rkb_XX34AN6MTfbQpsbZk03uIpLCs/exec?action=getAllBookings",
        "options": {}
      },
      "id": "sdr-0001-0001-0001-000000000002",
      "name": "Get All Bookings",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [160, 112]
    },
    {
      "parameters": {
        "jsCode": "const bookings = $input.first().json.bookings || [];\nconst now = new Date();\nconst ist = new Date(now.getTime() + (5.5 * 60 * 60 * 1000));\nconst todayStr = String(ist.getDate()).padStart(2,'0') + '-' + String(ist.getMonth()+1).padStart(2,'0') + '-' + ist.getFullYear();\n\nconst filtered = bookings.filter(b => b.date === todayStr && b.status !== 'Cancelled');\n\nreturn filtered.map(b => {\n  let timeFormatted = String(b.time || '');\n  const t = timeFormatted.toLowerCase().trim();\n  const match24 = t.match(/^(\\d{1,2}):(\\d{2})$/);\n  if (match24) {\n    const h = parseInt(match24[1]);\n    if (h === 0) timeFormatted = '12am';\n    else if (h < 12) timeFormatted = h + 'am';\n    else if (h === 12) timeFormatted = '12pm';\n    else timeFormatted = (h - 12) + 'pm';\n  }\n  return { json: { ...b, timeFormatted } };\n});"
      },
      "id": "sdr-0001-0001-0001-000000000003",
      "name": "Filter Today Bookings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 112]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 3 },
          "conditions": [{ "id": "sdr-cond-001", "leftValue": "={{ $json.phone }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty" } }],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
