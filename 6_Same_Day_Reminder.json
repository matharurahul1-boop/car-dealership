        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer EAAXR63I2WKMBR0AbS6rCldgll8dvhzuRZBcyVIadaLucXu1CMcHAPozZA2R8eZB8NPKXlDvuZCrb2bzzolMrkycoCgjZA4x81LLs04g5lo5M8w5SMTGZA6YKEFKVfPMkx3dngK2JgM9fuuSlWvBIQcaAZAZCQhzPlFLSgWrCHhJ6OIPLNzcuA0ZAiYd0ZB8S2sAFX7DTCyYSyVd7prNZCWwUyJrHWlDqeB25iAOckTHJXSpGZCcRcHWpaNBabDegci9k8SsfTzgpIF2z42U08JrYLXNi" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.phone }}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Good morning {{ $json.name }}! ☀️\\n\\nThis is a reminder from Handysolver Car Dealership 🚗\\n\\nYour *{{ $json.car }}* test drive is scheduled for *today* at *{{ $json.timeFormatted }}*.\\n\\nWe look forward to seeing you! 😊\\n\\n_Handysolver Car Dealership_\"\n  }\n}",
        "options": {}
      },
      "id": "sdr-0001-0001-0001-000000000005",
